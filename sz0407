    <div id="toast" class="fixed bottom-12 left-1/2 -translate-x-1/2 bg-gray-900 text-white px-10 py-5 rounded-[1.5rem] text-sm font-bold shadow-2xl opacity-0 transition-all pointer-events-none z-[100] border border-gray-700"></div>

    <script type="module">
        // --- 雲端數據與同步邏輯 ---
        // 考慮到大陸直連，此處建議對接 Cloudflare Worker 或 國內雲
        // 目前先使用 localStorage 進行演示，並預留 Fetch 接口
        
        async function fetchCloudExams() {
            if (!CLOUDFLARE_WORKER_API) {
                const localData = localStorage.getItem('china_direct_exams');
                return localData ? JSON.parse(localData) : [];
            }
            try {
                const res = await fetch(CLOUDFLARE_WORKER_API + "/getExams");
                return await res.json();
            } catch (e) { return []; }
        }

        async function saveExamToCloud(examData) {
            if (!CLOUDFLARE_WORKER_API) {
                const current = await fetchCloudExams();
                current.push({ id: Date.now().toString(), ...examData });
                localStorage.setItem('china_direct_exams', JSON.stringify(current));
                return true;
            }
            try {
                await fetch(CLOUDFLARE_WORKER_API + "/saveExam", {
                    method: 'POST',
                    body: JSON.stringify(examData)
                });
                return true;
            } catch (e) { return false; }
        }

        // --- 學員邏輯 ---
        window.onSelectCategory = async (cat) => {
            window.currentCategory = cat;
            window.currentView = 'unitSelect';
            document.getElementById('selectedCatTitle').innerText = `${cat} 練習專區`;
            document.getElementById('learnerHome').classList.add('hidden');
            document.getElementById('unitSelectView').classList.remove('hidden');
            window.showToast(`正在讀取 ${cat} 雲端單元...`);
            window.allExams = await fetchCloudExams();
            window.renderUnitSelect();
        };

        window.renderUnitSelect = () => {
            const list = document.getElementById('unitList');
            const units = (window.allExams || []).filter(e => e.category === window.currentCategory);
            
            if (units.length === 0) {
                list.innerHTML = `<div class="col-span-full text-center py-20 text-gray-300 italic">目前本分組尚無發布考題單元。</div>`;
                return;
            }

            list.innerHTML = units.map(u => `
                <div onclick="window.startExam('${u.id}')" class="bg-white p-7 rounded-[2rem] shadow-sm border border-gray-50 card-hover cursor-pointer group">
                    <h4 class="font-bold text-gray-700 text-lg mb-2 group-hover:esun-text-green transition-colors">${u.title}</h4>
                    <div class="flex justify-between items-center">
                        <span class="text-[10px] bg-gray-50 text-gray-400 px-3 py-1 rounded-full font-mono font-bold">${u.questions.length} 題測驗</span>
                        <span class="text-[10px] font-bold esun-text-gold opacity-0 group-hover:opacity-100 transition-all">啟動挑戰 →</span>
                    </div>
                </div>
            `).join('');
        };

        window.startExam = (examId) => {
            const exam = window.allExams.find(e => e.id === examId);
            if (!exam) return;
            window.quizData = exam.questions;
            window.currentIdx = 0; window.score = 0;
            document.getElementById('unitSelectView').classList.add('hidden');
            document.getElementById('learnerQuiz').classList.remove('hidden');
            document.getElementById('unit-badge').innerText = exam.title;
            window.renderQuestion();
        };

        window.backToCategories = () => {
            window.currentView = 'home';
            document.getElementById('unitSelectView').classList.add('hidden');
            document.getElementById('learnerHome').classList.remove('hidden');
        };

        window.backToUnits = () => {
            window.currentView = 'unitSelect';
            document.getElementById('learnerQuiz').classList.add('hidden');
            document.getElementById('unitSelectView').classList.remove('hidden');
            window.renderUnitSelect();
        };

        window.renderQuestion = () => {
            const container = document.getElementById('quiz-container');
            const result = document.getElementById('result-screen');
            if (!window.quizData[window.currentIdx]) return;
            const item = window.quizData[window.currentIdx];
            
            result.classList.add('hidden'); 
            container.classList.remove('hidden');
            
            document.getElementById('prog-text').innerText = `${(window.currentIdx + 1).toString().padStart(2, '0')} / ${window.quizData.length.toString().padStart(2, '0')}`;
            document.getElementById('prog-bar').style.width = `${((window.currentIdx + 1) / window.quizData.length) * 100}%`;
            
            container.innerHTML = `
                <div class="bg-white rounded-[2.5rem] shadow-sm p-10 mb-8 slide-in border border-gray-50">
                    <div class="mb-10">
                        <span class="text-[10px] font-bold esun-text-gold uppercase tracking-[0.2em] mb-2 block">Case Analysis</span>
                        <h3 class="text-2xl font-bold text-gray-800 leading-snug">${item.q}</h3>
                    </div>
                    <div class="space-y-4">
                        ${item.o.map((opt, i) => `
                            <button onclick="window.handleSelect(${i})" class="quiz-btn w-full text-left p-6 rounded-2xl border-2 border-gray-50 hover:esun-border-green hover:bg-green-50 transition-all font-medium text-gray-700 shadow-sm flex justify-between items-center group">
                                <span>${opt}</span>
                                <div class="w-2 h-2 rounded-full esun-bg-gold opacity-0 group-hover:opacity-100 transition-all"></div>
                            </button>`).join('')}
                    </div>
                    <div id="expl-box" class="hidden mt-12 p-8 bg-[#fdfaf2] rounded-3xl border-l-8 esun-border-gold shadow-sm">
                        <div class="flex items-start gap-4">
                            <span class="text-3xl mt-1">💡</span>
                            <div class="text-base leading-relaxed text-gray-800">
                                <span class="font-bold block mb-3 text-lg esun-text-green border-b border-green-100 pb-1 underline decoration-gold">專家解析與指導</span>
                                ${item.i}
                            </div>
                        </div>
                        <button onclick="window.nextQuest()" class="mt-10 w-full esun-bg-green text-white py-5 rounded-2xl font-bold text-sm shadow-xl active:scale-95 transition-all">繼續下一個考題</button>
                    </div>
                </div>
            `;
        };

        window.handleSelect = (idx) => {
            const correct = window.quizData[window.currentIdx].a;
            const btns = document.querySelectorAll('.quiz-btn');
            btns.forEach(b => b.disabled = true);
            if (idx == correct) { 
                window.score++; 
                btns[idx].classList.add('bg-green-100', 'esun-border-green', 'esun-text-green'); 
            } else { 
                btns[idx].classList.add('bg-red-50', 'border-red-500', 'text-red-700'); 
                btns[correct].classList.add('bg-green-100', 'esun-border-green', 'esun-text-green'); 
            }
            document.getElementById('expl-box').classList.remove('hidden');
            document.getElementById('expl-box').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        };

        window.nextQuest = () => { 
            window.currentIdx++; 
            if (window.currentIdx < window.quizData.length) window.renderQuestion(); else window.showResult(); 
        };

        window.showResult = () => { 
            document.getElementById('quiz-container').classList.add('hidden'); 
            document.getElementById('result-screen').classList.remove('hidden'); 
            document.getElementById('result-msg').innerText = `非常優秀！本次練習答對了 ${window.score} 題。持續練習，成就銀行家專業。`; 
        };

        window.restartQuiz = () => { window.currentIdx = 0; window.score = 0; window.renderQuestion(); };

        // --- 管理邏輯：整批解析 ---
        const fileInput = document.getElementById('fileInput');
        document.getElementById('dropZone').onclick = () => fileInput.click();
        
        fileInput.onchange = async (e) => {
            const files = Array.from(e.target.files);
            if (files.length === 0) return;
            window.uploadedImages = []; 
            
            for (let i = 0; i < files.length; i++) {
                const file = files[i];
                window.showToast(`正在讀取 (${i+1}/${files.length}): ${file.name}`);
                
                if (file.type === "application/pdf") {
                    try {
                        const arrayBuffer = await file.arrayBuffer();
                        const pdf = await pdfjsLib.getDocument(new Uint8Array(arrayBuffer)).promise;
                        let text = ""; 
                        for (let p = 1; p <= pdf.numPages; p++) { 
                            const page = await pdf.getPage(p); 
                            const content = await page.getTextContent(); 
                            text += content.items.map(s => s.str).join(" ") + "\n"; 
                        }
                        document.getElementById('rawText').value += `\n[ PDF 導入: ${file.name} ]\n` + text;
                    } catch (err) { console.error("PDF 解析失敗:", err); }
                } else if (file.name.endsWith(".docx")) {
                    try {
                        const arrayBuffer = await file.arrayBuffer();
                        const res = await mammoth.extractRawText({ arrayBuffer });
                        document.getElementById('rawText').value += `\n[ Word 導入: ${file.name} ]\n` + res.value;
                    } catch (err) { console.error("Word 解析失敗:", err); }
                } else if (file.type.startsWith("image/")) {
                    const base64 = await new Promise(resolve => {
                        const reader = new FileReader();
                        reader.onload = () => resolve(reader.result.split(',')[1]);
                        reader.readAsDataURL(file);
                    });
                    window.uploadedImages.push(base64);
                    document.getElementById('rawText').value += `\n[ 圖片素材掛載: ${file.name} ]\n`;
                }
            }
            window.showToast(`✅ 已整批讀取 ${files.length} 個檔案`);
        };

        document.getElementById('addManualBtn').onclick = () => {
            const count = window.tempEditData.length; if (count >= 15) return window.showToast("單份卷宗上限 15 題。");
            const requested = parseInt(document.getElementById('batchCountSelect').value);
            const toAdd = Math.min(requested, 15 - count);
            for (let i = 0; i < toAdd; i++) window.tempEditData.push({ q: "手動新增題目：請點擊編輯內容", o: ["選項 A", "選項 B", "選項 C", "選項 D"], a: 0, i: "專家解析說明。" });
            window.renderEditCards();
        };

        // --- DeepSeek 智能出題 (直連版) ---
        document.getElementById('aiGenBtn').onclick = async () => {
            if (!DEEPSEEK_API_KEY) return window.showToast("⚠️ 請先在程式碼中填入 DeepSeek API Key");
            const text = document.getElementById('rawText').value;
            const requested = parseInt(document.getElementById('batchCountSelect').value);
            if (!text && window.uploadedImages.length === 0) return window.showToast("行長，請先整批導入素材。");
            
            const toGen = Math.min(requested, 15 - window.tempEditData.length);
            const loader = document.getElementById('aiLoader'); 
            loader.classList.remove('hidden');
            
            try {
                const data = await callDeepSeek(text, window.uploadedImages, toGen);
                window.tempEditData = window.tempEditData.concat(data); 
                window.renderEditCards();
                window.showToast("DeepSeek 知識提取成功！");
            } catch (e) { window.showToast("DeepSeek 服務忙碌或 Key 無效，請重試。"); }
            loader.classList.add('hidden');
        };

        async function callDeepSeek(text, imgs, count) {
            // DeepSeek API 是 OpenAI 相容格式
            const prompt = `你是一位資深銀行合規與培訓專家。請深度閱讀以下法規素材並產出 ${count} 題具備高度嚴謹度的單選練習題。
題目必須包含：題目(q)、四個選項(o)、正確選項索引(a, 0-3)、專家解析(i)。
請確保解析內容包含實務操作指引。
返回格式必須是純 JSON 數組，禁止任何 Markdown 標籤：[{"q":"...","o":["..."],"a":0,"i":"..."}]
法規內容：\n${text}`;

            const response = await fetch(DEEPSEEK_ENDPOINT, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${DEEPSEEK_API_KEY}`
                },
                body: JSON.stringify({
                    model: "deepseek-chat",
                    messages: [{ role: "user", content: prompt }],
                    temperature: 0.7
                })
            });

            const res = await response.json();
            const content = res.choices[0].message.content;
            return JSON.parse(content.replace(/```json/g, '').replace(/```/g, '').trim());
        }

        window.renderEditCards = () => {
            const area = document.getElementById('editArea');
            const count = window.tempEditData.length;
            document.getElementById('qCountDisplay').innerText = `${count} / 15`;
            document.getElementById('qCountTop').innerText = count;

            if (count === 0) { area.innerHTML = `<div class="text-center py-40 text-gray-200 italic flex flex-col items-center"><div class="text-6xl mb-4">📥</div><p>尚未導入考題素材。</p></div>`; return; }
            area.innerHTML = window.tempEditData.map((d, i) => `
                <div class="bg-gray-50 p-8 rounded-[2rem] border border-gray-100 slide-in mb-6 relative hover:bg-white transition-all shadow-sm group">
                    <button onclick="window.deleteQuestion(${i})" class="absolute top-8 right-8 text-gray-300 hover:text-red-500 transition-colors opacity-0 group-hover:opacity-100">🗑️</button>
                    <div class="flex items-center gap-4 mb-6">
                        <span class="esun-bg-green text-white w-8 h-8 rounded-full text-xs flex items-center justify-center font-bold font-mono">${i+1}</span>
                        <input type="text" value="${d.q}" oninput="window.tempEditData[${i}].q=this.value" class="flex-1 font-bold bg-transparent border-b-2 border-gray-100 focus:esun-border-green focus:outline-none py-2 text-gray-800 text-lg">
                    </div>
                    <div class="grid grid-cols-2 gap-4 pl-12">
                        ${d.o.map((o, oi) => `
                            <div class="flex items-center gap-3 bg-white p-3 rounded-xl border border-gray-50">
                                <input type="radio" name="corr_${i}" ${d.a == oi ? 'checked' : ''} onchange="window.tempEditData[${i}].a=${oi}" class="accent-emerald-600">
                                <input type="text" value="${o}" oninput="window.tempEditData[${i}].o[${oi}]=this.value" class="text-sm w-full focus:outline-none bg-transparent">
                            </div>`).join('')}
                    </div>
                    <div class="mt-6 pl-12 flex gap-4 bg-yellow-50 p-6 rounded-2xl border border-yellow-100">
                        <span class="text-2xl">💡</span>
                        <div class="flex-1">
                            <label class="block text-[10px] font-bold text-yellow-600 mb-2 uppercase tracking-widest font-mono italic">Expert Guidance</label>
                            <textarea oninput="window.tempEditData[${i}].i=this.value" class="w-full bg-transparent text-sm text-yellow-900 focus:outline-none resize-none leading-relaxed font-medium" rows="3" placeholder="在此輸入行長對此題的經驗指導...">${d.i}</textarea>
                        </div>
                    </div>
                </div>
            `).join('');
        };

        window.deleteQuestion = (idx) => { window.tempEditData.splice(idx, 1); window.renderEditCards(); };

        window.switchAdminCat = (cat) => {
            window.currentCategory = cat;
            document.getElementById('currentAdminCatDisplay').innerText = `[${cat}]`;
            document.querySelectorAll('.admin-cat-btn').forEach(btn => {
                btn.className = btn.innerText === cat 
                    ? "admin-cat-btn px-6 py-2.5 rounded-xl text-sm font-bold esun-bg-green text-white shadow-lg transition-all"
                    : "admin-cat-btn px-6 py-2.5 rounded-xl text-sm font-bold bg-gray-50 text-gray-400 hover:bg-gray-100";
            });
            window.tempEditData = []; 
            document.getElementById('unitTitleInput').value = "";
            window.renderEditCards();
        };

        document.getElementById('publishBtn').onclick = async () => {
            const title = document.getElementById('unitTitleInput').value;
            if (!title) return window.showToast("⚠️ 請先定義卷宗名稱。");
            if (window.tempEditData.length === 0) return window.showToast("⚠️ 目前沒有可發布題目。");
            
            const btn = document.getElementById('publishBtn');
            btn.disabled = true; btn.innerText = "資料同步中...";
            
            const success = await saveExamToCloud({
                category: window.currentCategory,
                title: title,
                questions: window.tempEditData,
                timestamp: Date.now()
            });

            if (success) {
                window.showToast(`✅ 【${title}】已發布成功！`);
                window.tempEditData = []; document.getElementById('unitTitleInput').value = ""; window.renderEditCards();
            } else {
                window.showToast("❌ 雲端存取失敗。");
            }
            btn.disabled = false; btn.innerText = "🚀 正式發布雲端";
        };

        window.showToast = (msg) => {
            const t = document.getElementById('toast');
            t.innerText = msg; t.classList.remove('opacity-0');
            setTimeout(() => t.classList.add('opacity-0'), 3000);
        };

        const lBtn = document.getElementById('viewLearner');
        const aBtn = document.getElementById('viewAdmin');
        lBtn.onclick = () => {
            window.currentMode = 'learner';
            document.getElementById('learnerSection').classList.remove('hidden');
            document.getElementById('adminSection').classList.add('hidden');
            lBtn.className = "text-xs px-5 py-2 rounded-lg font-bold bg-white esun-text-green shadow-sm";
            aBtn.className = "text-xs px-5 py-2 rounded-lg font-bold text-gray-400 hover:text-gray-600 ml-1";
            window.backToCategories();
        };
        aBtn.onclick = () => {
            window.currentMode = 'admin';
            document.getElementById('learnerSection').classList.add('hidden');
            document.getElementById('adminSection').classList.remove('hidden');
            aBtn.className = "text-xs px-5 py-2 rounded-lg font-bold bg-white esun-text-green shadow-sm";
            lBtn.className = "text-xs px-5 py-2 rounded-lg font-bold text-gray-400 hover:text-gray-600 ml-1";
            window.switchAdminCat(window.currentCategory);
        };

        window.onload = () => {
            console.log("China Direct System Loaded.");
        };
    </script>
</body>
</html>
